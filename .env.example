# ─────────────────────────────────────────────────────────────
# Ayalas — variables de entorno (copiar a .env y rellenar)
# ─────────────────────────────────────────────────────────────

# Base de datos PostgreSQL propia del proyecto (en el VPS: ayalas_db con su usuario)
DATABASE_URL="postgresql://ayalas:ayalas@localhost:5433/ayalas_db?schema=public"

# Secreto para firmar la cookie de sesión del CRM (iron-session).
# DEBE tener al menos 32 caracteres. Genera uno: `openssl rand -base64 32`
SESSION_SECRET="cambia-esto-por-un-secreto-largo-de-al-menos-32-caracteres"

# Admin inicial que crea el seed (personal del gym que entra al CRM).
ADMIN_EMAIL="admin@ayalas.local"
ADMIN_PASSWORD="cambiame"
ADMIN_NAME="Administrador Ayalas"

# Clave compartida entre el orquestador (n8n) y los endpoints /api/bot/*
BOT_API_KEY="cambia-esta-clave-del-bot"

# ── Meta / WhatsApp Business Cloud API ──
# GOTCHA #1: el token DEBE ser de System User permanente (caducidad "Nunca").
# Los temporales expiran y rompen el ENVÍO en silencio (error code 190).
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
# Versión del Graph API a usar al enviar (consistencia: v25.0)
META_GRAPH_VERSION="v25.0"

# Zona horaria del gimnasio para las métricas del dashboard (offset manual / luxon)
GYM_TIMEZONE="America/Mexico_City"
